# ==============================================
# Skill Optimizer 环境变量配置文件
# ==============================================
# 请复制此文件为 .env 并填写实际的值
# 命令: cp .env.example .env
# ==============================================

# ==============================================
# LLM (大模型) 配置 - 必填
# ==============================================
# DeepSeek API 密钥（若不使用 DeepSeek，可配置 OPENAI_API_KEY）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 基础 URL，默认 https://api.deepseek.com/
DEEPSEEK_BASE_URL=https://api.deepseek.com/

# 使用的模型名称，默认 deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# 备选：如果使用 OpenAI，请填写以下密钥（DEEPSEEK_API_KEY 和 OPENAI_API_KEY 二选一）
# OPENAI_API_KEY=your_openai_api_key_here


# ==============================================
# 监控与反馈 - 可选
# ==============================================
# Langfuse 公钥，用于记录优化 Trace
# LANGFUSE_PUBLIC_KEY=your_langfuse_public_key

# Langfuse 私钥
# LANGFUSE_SECRET_KEY=your_langfuse_secret_key

# 默认的人工反馈文件路径
# HUMAN_FEEDBACK_FILE=/path/to/feedback.txt

# ==============================================
# 路径与策略配置 - 可选
# ==============================================
# 待优化的 Skill �默认目录路径
# OPT_SKILLS_DIR=/path/to/skills

# 优化结果默认输出目录
# OPT_OUTPUT_DIR=/path/to/output

# 并行优化的最大工作线程数
# OPTIMIZATION_MAX_WORKERS=4
