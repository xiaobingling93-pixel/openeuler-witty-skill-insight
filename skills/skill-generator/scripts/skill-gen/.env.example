# ------------------------------------------------------------
# LLM 判题配置
# ------------------------------------------------------------
# 用于自动评分的 LLM API Key 和模型配置
# 请在看板「Settings」页面进行配置（支持 DeepSeek、OpenAI 等）
# 不再通过环境变量配置

# ------------------------------------------------------------
# Skill 生成配置
# ------------------------------------------------------------
# DeepSeek API 配置
# 获取 API Key: https://platform.deepseek.com/
# 注意：此配置用于 Skill 生成模块，与判题配置独立
DEEPSEEK_API_KEY=sk-xxxx-xxxx-xxxx-xxxx
DEEPSEEK_BASE_URL="https://api.deepseek.com/"
DEEPSEEK_MODEL="deepseek-chat"

# LLM API 配置（用于 skill-gen，优先级高于 DEEPSEEK_*）
# 如果设置了 LLM_API_KEY，将使用这些配置；否则回退到 DEEPSEEK_*
# LLM_API_KEY=sk-xxxx-xxxx-xxxx-xxxx
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1

# Skill 输出目录（命令行模式必需）
# 命令行模式下，如果不通过 --output 参数指定，将使用此环境变量
# API 模式下，输出路径由 API 自动管理，无需设置此变量
# 默认值：./data/storage/skills/generated
CUSTOM_SKILL_PATHS=./custom_skills