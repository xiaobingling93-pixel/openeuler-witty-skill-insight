# ============================================================
# Witty-Skill-Insight 环境配置
# ============================================================
# 复制此文件为 .env 并根据需要修改
# cp .env.example .env

# ------------------------------------------------------------
# 数据库配置（必填）
# ------------------------------------------------------------
# SQLite 数据库文件路径
# 数据库存储在 ~/.skill-insight/data/ 目录下
DATABASE_URL="file:../data/witty_insight.db"

# opengauss数据库配置（可选，配置后将使用 OpenGauss，否则使用 SQLite）
# DB_HOST=
# DB_PORT=
# DB_NAME=postgres
# DB_USER=
# DB_PASSWORD=

# ------------------------------------------------------------
# 默认模型配置（可选）
# ------------------------------------------------------------
# 支持配置多个模型，按编号 1, 2, 3... 递增
# 格式：DEFAULT_MODEL_<N>_<FIELD>
#
# 可用字段：
# - NAME: 配置名称
# - PROVIDER: 提供商 (deepseek | openai | anthropic | siliconflow | custom)
# - API_KEY: API 密钥
# - BASE_URL: API 基础 URL（可选）
# - MODEL: 模型名称
#
# 注意：
# - 环境变量配置是只读的，不能在 UI 中修改或删除
# - 用户可以在 UI 中创建自己的配置
# - 服务启动时会自动激活第一个默认配置
#
# 示例：
# DEFAULT_MODEL_1_NAME=DeepSeek Default
# DEFAULT_MODEL_1_PROVIDER=deepseek
# DEFAULT_MODEL_1_API_KEY=sk-xxx
# DEFAULT_MODEL_1_BASE_URL=https://api.deepseek.com
# DEFAULT_MODEL_1_MODEL=deepseek-chat
#
# DEFAULT_MODEL_2_NAME=OpenAI Proxy
# DEFAULT_MODEL_2_PROVIDER=custom
# DEFAULT_MODEL_2_API_KEY=sk-yyy
# DEFAULT_MODEL_2_BASE_URL=https://api.openai.com/v1
# DEFAULT_MODEL_2_MODEL=gpt-4o


# ------------------------------------------------------------
# API Key（可选）
# ------------------------------------------------------------
# Dashboard 颁发的 API Key，用于：
# 1. 采集脚本向 Dashboard 上报数据时的身份识别
# 2. Skill 同步时的用户隔离
# 可在看板右上角生成
# WITTY_INSIGHT_API_KEY=sk-xxxx

# ------------------------------------------------------------
# 网络代理（可选，企业内网环境可能需要）
# ------------------------------------------------------------
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# no_proxy=localhost,127.0.0.1

# SSL 证书校验（仅在自签名证书环境下设为 0）
# NODE_TLS_REJECT_UNAUTHORIZED=1

# ------------------------------------------------------------
# 企业模式配置（可选）
# ------------------------------------------------------------
# 启用企业模式后，将从企业系统获取用户信息
# ORGANIZATION_MODE=true 时启用企业模式，false 或不设置时使用独立模式
ORGANIZATION_MODE=false

# 企业用户信息接口完整地址
ORG_USER_INFO_URL=

# 企业登录页地址（直接访问 /login 时跳转）
ORG_LOGIN_REDIRECT_URL=

# 企业技能同步配置
ORG_SKILL_LIST_URL=
ORG_SKILL_DOWNLOAD_URL=
ORG_SKILL_DELETE_URL_BASE=

# ------------------------------------------------------------
# URL 前缀配置（用于嵌入其他网页时）
# ------------------------------------------------------------
# 设置后，所有 API 请求会自动添加此前缀
# 例如设置为 /skill-insight 后，API 请求会变成 /skill-insight/api/xxx
# 不设置或留空时，保持默认行为（/api/xxx）
NEXT_PUBLIC_URL_PREFIX=